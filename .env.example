# ─────────────────────────────────────────────────────────────
# Rangeen Pixels — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────


# ── SERVER ───────────────────────────────────────────────────

PORT=3000
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173


# ── DATABASE (PostgreSQL) ─────────────────────────────────────

DATABASE_URL=postgresql://postgres:password@localhost:5432/rangeen_pixels


# ── AUTH ──────────────────────────────────────────────────────

JWT_SECRET=change-this-to-a-long-random-secret


# ── EMAIL (Nodemailer / SMTP) ─────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=Rangeen Pixels <noreply@rangeenpixels.club>


# ── STORAGE (S3-compatible — for photo uploads) ───────────────

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_BUCKET=rangeen-pixels-photos
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_CDN_URL=


# ── DEBUG (optional) ──────────────────────────────────────────

DEBUG_SQL=false